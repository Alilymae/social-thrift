{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "displayNameLower": { "type": "string", "description": "Lowercase display name for case-insensitive search" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "tier": { "type": "string", "enum": ["basic", "premium"] },
        "generationCount": { "type": "integer", "description": "Number of AI images generated" },
        "lastGenerationAt": { "type": "string", "format": "date-time", "description": "Timestamp of last generation for spam protection" }
      },
      "required": ["uid", "displayName", "tier"]
    },
    "Garment": {
      "title": "Garment",
      "description": "A single clothing item in a user's wardrobe",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ownerId", "imageUrl", "category"]
    },
    "Outfit": {
      "title": "Outfit",
      "description": "A styled combination of garments",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "garmentId": { "type": "string" },
              "imageUrl": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "scale": { "type": "number" },
              "rotation": { "type": "number" }
            }
          }
        },
        "likesCount": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "items", "isPublic"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on an outfit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "outfitId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["outfitId", "authorId", "text"]
    },
    "Listing": {
      "title": "Listing",
      "description": "An item for sale in the marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerTier": { "type": "string", "enum": ["basic", "premium"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "sold"] },
        "qualityRating": { "type": "string", "description": "Quality of item (e.g., Brand New, Second Hand)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sellerId", "title", "price", "imageUrl"]
    },
    "Tutorial": {
      "title": "Tutorial",
      "description": "An upcycling tutorial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "videoUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "likesCount": { "type": "integer" },
        "commentsCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "title", "videoUrl"]
    },
    "TutorialOutput": {
      "title": "TutorialOutput",
      "description": "A user-submitted result of an upcycling tutorial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tutorialId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["tutorialId", "userId", "imageUrl"]
    },
    "SavedRecommendation": {
      "title": "SavedRecommendation",
      "description": "An AI Lab style recommendation saved by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "summary": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "imageUrl", "summary", "isPublic"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between two users",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    },
    "Subscriber": {
      "title": "Subscriber",
      "description": "A newsletter subscriber",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "subscribedAt": { "type": "string", "format": "date-time" },
        "active": { "type": "boolean" }
      },
      "required": ["email", "subscribedAt", "active"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/garments/{garmentId}": {
      "schema": "Garment",
      "description": "Individual wardrobe items"
    },
    "/outfits/{outfitId}": {
      "schema": "Outfit",
      "description": "Styled outfits"
    },
    "/outfits/{outfitId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on outfits"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Marketplace listings"
    },
    "/tutorials/{tutorialId}": {
      "schema": "Tutorial",
      "description": "Upcycling tutorials"
    },
    "/tutorials/{tutorialId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on tutorials"
    },
    "/tutorial_outputs/{outputId}": {
      "schema": "TutorialOutput",
      "description": "Community results for tutorials"
    },
    "/saved_recommendations/{recommendationId}": {
      "schema": "SavedRecommendation",
      "description": "Saved AI Lab recommendations"
    },
    "/follows/{followId}": {
      "schema": "Follow",
      "description": "Follow relationships"
    },
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Newsletter subscribers"
    }
  }
}
